# ── Helen-Server environment ──────────────────────────────────
# sourced by /usr/bin/helen-server and systemd unit via EnvironmentFile
# Edit this file, then:  sudo systemctl restart helen-server

# Network
PORT=3000
HELEN_HOST=0.0.0.0

# HTTPS — 1 = disable (use when behind a TLS-terminating reverse proxy)
HELEN_HTTPS_DISABLED=0
HELEN_HTTPS_PORT=3443

# Paths — FHS-compliant defaults
COMMCLIENT_DATA_DIR=/var/lib/helen
COMMCLIENT_LOG_DIR=/var/log/helen

# Rendezvous reverse tunnel (optional — leave unset for LAN-only)
# HELEN_RENDEZVOUS_WS_URL=ws://rendezvous.example:9090/tunnel/register
# HELEN_RENDEZVOUS_TOKEN=

# Tuning
UVICORN_BACKLOG=8192
RATE_LIMIT_GLOBAL_ENABLED=1
RATE_LIMIT_TRUST_LAN=1

# Logging
LOG_LEVEL=INFO
DEBUG=0
