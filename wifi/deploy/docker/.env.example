# Helen — docker compose .env (LAN-only deployment)
#
# Generate strong values BEFORE first `docker compose up`.

# JWT secret — used to sign all auth tokens. Must be 32+ chars.
# Generate: openssl rand -hex 32
JWT_SECRET=

# Rendezvous token — required ONLY if you run helen-rendezvous (multi-LAN).
# Generate: openssl rand -hex 32
HELEN_RENDEZVOUS_TOKEN=

# Rendezvous URL — leave empty unless you have a separate rendezvous host.
# Example: http://10.0.0.10:9090
HELEN_RENDEZVOUS_URL=

# Optional: pin to a specific LAN IP for binding (else 0.0.0.0)
# HELEN_BIND_IP=10.0.0.5
