{
  "name": "commclient-mobile",
  "version": "1.0.0",
  "description": "Helen Mobile — Android client for the CommClient LAN platform. Wraps the same React renderer the desktop app uses, via Capacitor.",
  "private": true,
  "scripts": {
    "build:web": "node scripts/sync-renderer.mjs",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "android:release": "cd android && ./gradlew assembleRelease",
    "build:apk": "npm run build:web && npm run cap:sync && npm run android:debug"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/device": "^6.0.1",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.2",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/network": "^6.0.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/push-notifications": "^6.0.2",
    "@capacitor/share": "^6.0.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@capacitor/toast": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
