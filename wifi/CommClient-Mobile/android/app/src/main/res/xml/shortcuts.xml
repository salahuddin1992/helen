<?xml version="1.0" encoding="utf-8"?>
<!--
  Helen — App Shortcuts (API 25+).

  Long-press the launcher icon to surface these. Each fires a deep
  link `helen://shortcut/<action>` which the renderer parses through
  Capacitor's existing appUrlOpen listener (mobile-bridge.js routes
  it the same way it routes incoming-call decisions).

  Limit: at most 5 visible shortcuts; fewer is preferable for
  scannability. Icons reference monochrome drawables that fall back
  cleanly under adaptive icon theming.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="new_chat"
        android:enabled="true"
        android:icon="@android:drawable/ic_dialog_email"
        android:shortcutShortLabel="@string/shortcut_new_chat_short"
        android:shortcutLongLabel="@string/shortcut_new_chat_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.helen.mobile"
            android:targetClass="com.helen.mobile.MainActivity"
            android:data="helen://shortcut/new-chat" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

    <shortcut
        android:shortcutId="search_contacts"
        android:enabled="true"
        android:icon="@android:drawable/ic_menu_search"
        android:shortcutShortLabel="@string/shortcut_search_short"
        android:shortcutLongLabel="@string/shortcut_search_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.helen.mobile"
            android:targetClass="com.helen.mobile.MainActivity"
            android:data="helen://shortcut/search-contacts" />
    </shortcut>

    <shortcut
        android:shortcutId="start_call"
        android:enabled="true"
        android:icon="@android:drawable/ic_menu_call"
        android:shortcutShortLabel="@string/shortcut_call_short"
        android:shortcutLongLabel="@string/shortcut_call_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.helen.mobile"
            android:targetClass="com.helen.mobile.MainActivity"
            android:data="helen://shortcut/start-call" />
    </shortcut>

    <shortcut
        android:shortcutId="recent_calls"
        android:enabled="true"
        android:icon="@android:drawable/ic_menu_recent_history"
        android:shortcutShortLabel="@string/shortcut_recents_short"
        android:shortcutLongLabel="@string/shortcut_recents_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.helen.mobile"
            android:targetClass="com.helen.mobile.MainActivity"
            android:data="helen://shortcut/recents" />
    </shortcut>

</shortcuts>
