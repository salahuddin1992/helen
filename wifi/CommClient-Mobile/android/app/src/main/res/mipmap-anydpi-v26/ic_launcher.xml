<?xml version="1.0" encoding="utf-8"?>
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background"/>
    <foreground android:drawable="@mipmap/ic_launcher_foreground"/>
    <!-- Themed icon (Android 13+). When the user enables "Themed icons"
         in Pixel Launcher / OneUI / etc., this layer is recolored by
         the system to match the wallpaper accent. Re-using the
         foreground mipmap is the canonical pattern when the foreground
         is already a flat monochrome silhouette. -->
    <monochrome android:drawable="@mipmap/ic_launcher_foreground"/>
</adaptive-icon>