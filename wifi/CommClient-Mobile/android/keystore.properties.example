# Copy this file to `keystore.properties` (sibling of build.gradle)
# and fill in your real release keystore credentials. The actual file
# is gitignored so the password never lands in source control.
#
# Alternatively, set HELEN_KEYSTORE_PASSWORD / HELEN_KEY_PASSWORD as
# environment variables on the build machine — build.gradle prefers
# the properties file, then the env vars, then the legacy hard-coded
# default.
storePassword=helen-release-2026
keyPassword=helen-release-2026
