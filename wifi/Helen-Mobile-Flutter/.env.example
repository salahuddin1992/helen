# Helen Mobile — environment configuration
# Copy to .env and edit values.

# Server URLs
HELEN_SERVER_URL=http://192.168.1.10:3000
HELEN_SOCKET_URL=ws://192.168.1.10:3000

# Deep link callbacks
HELEN_OAUTH_REDIRECT=helen://oauth/callback
HELEN_PAIRING_REDIRECT=helen://pair/callback

# Logging: trace | debug | info | warn | error | fatal | off
HELEN_LOG_LEVEL=debug

# HTTP timeouts (ms) and retry attempts
HELEN_CONNECT_TIMEOUT_MS=10000
HELEN_RECEIVE_TIMEOUT_MS=30000
HELEN_RETRY_ATTEMPTS=3

# App name (shown in UI)
HELEN_APP_NAME=Helen
