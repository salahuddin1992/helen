{
  "name": "helen-shell",
  "version": "1.0.0",
  "description": "Generic Electron shell for any Helen web panel. One binary, configurable per-app via CLI args (--id, --url, --title, --width, --height).",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "admin": "electron . --id=admin",
    "secret-admin": "electron . --id=secret-admin",
    "vault": "electron . --id=vault",
    "ios": "electron . --id=ios",
    "admin-mobile": "electron . --id=admin-mobile",
    "hub": "electron . --id=hub",
    "group-call": "electron . --id=group-call",
    "build": "electron-builder --win --config electron-builder.yml"
  },
  "devDependencies": {
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3"
  }
}
