{
  "name": "commclient-desktop",
  "version": "1.0.0",
  "description": "CommClient — LAN-only communication platform for Windows",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "author": {
    "name": "CommClient Team",
    "email": "noreply@example.com"
  },
  "homepage": "https://github.com/commclient/desktop",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "scripts": {
    "preinstall": "node -e \"const v=process.versions.node.split('.').map(Number);if(v[0]<16){console.error('Node 16+ required, found '+process.versions.node);process.exit(1)}\"",
    "prebuild": "node -e \"const fs=require('fs');const p='../CommClient-Server/dist/Helen-Server';if(!fs.existsSync(p)){fs.mkdirSync(p,{recursive:true});fs.writeFileSync(p+'/placeholder.txt','Server not bundled - will run from source')}\"",
    "dev": "vite",
    "build:renderer": "vite build",
    "build:electron": "npm run build:renderer && electron-builder --win --config electron-builder.yml",
    "build": "npm run prebuild && npm run build:renderer && electron-builder --win --config electron-builder.yml",
    "build:dir": "npm run prebuild && npm run build:renderer && electron-builder --win --dir --config electron-builder.yml",
    "preview": "vite preview",
    "electron:dev": "vite",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist-electron release",
    "rebuild": "npm run clean && npm run build"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.383.0",
    "mediasoup-client": "^3.7.16",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.23.1",
    "react-virtuoso": "^4.7.10",
    "simple-peer": "^9.11.1",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/simple-peer": "^9.11.8",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0"
  },
  "build": {
    "extends": null
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.21.5"
  }
}
