# CommClient Desktop Configuration
# ==================================
# Copy this file to .env and customize as needed.
# These values are used by Vite during build and by Electron at runtime.

# ── Server Connection ──────────────────────────────
# Default server URL (can be changed in app settings)
VITE_DEFAULT_SERVER_URL=http://localhost:3000

# ── Build ──────────────────────────────────────────
# Electron main process port in dev mode
VITE_DEV_SERVER_PORT=5173

# ── Debug ──────────────────────────────────────────
# Log level for the renderer process: DEBUG | INFO | WARN | ERROR
VITE_LOG_LEVEL=INFO

# ── App Metadata ───────────────────────────────────
VITE_APP_NAME=Helen Desktop
VITE_APP_VERSION=1.0.0
