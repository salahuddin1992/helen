# Helen-Admin environment
# Edit this file, then: sudo systemctl restart helen-admin-headless
#                       (or relaunch `helen-admin` for GUI)

HELEN_ADMIN_BASE=http://localhost:3000

# Never auto-spawn Helen-Server from within the admin process (1 = on)
HELEN_ADMIN_REMOTE=1

# Bind static admin HTTP on 0.0.0.0 (useful for headless service)
HELEN_ADMIN_EXPOSE_ON_LAN=1

# Static-file port
HELEN_ADMIN_PORT=5173
