{
  "name": "group-call-app",
  "productName": "Group Call",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal WebRTC group call — Express + Socket.IO signaling + peer-mesh client. Open the same `?room=<id>` URL in N tabs and they all see each other.",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win --config electron-builder.yml"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3"
  }
}
