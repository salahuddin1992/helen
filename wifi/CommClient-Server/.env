# CommClient Server Configuration
# ================================

# Server
HOST=0.0.0.0
PORT=3000
DEBUG=false
LOG_LEVEL=INFO

# Database (sqlite or postgresql)
DB_BACKEND=sqlite
# Absolute path so the standalone server shares the same DB as the bundled
# server inside Helen Desktop (which uses %APPDATA%/CommClient/data/). Without
# this, the two servers would have separate user accounts and tokens issued
# by one would resolve to a non-existent user on the other.
SQLITE_PATH=C:/Users/youse/AppData/Roaming/CommClient/data/commclient.db
# PostgreSQL (uncomment when migrating)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/commclient

# JWT — must match the persisted .secrets.json jwt_secret value used by the
# bundled server (loaded via app.core.persistent_secrets). Otherwise tokens
# issued by the bundled server are rejected by this one and vice versa,
# causing the desktop client to bounce between "connected" and "disconnected"
# depending on which server it auto-discovers first (3000 vs 3001).
JWT_SECRET=kIq8VwfYbwRaoyY1s6nAmgKNUVQupuvXBLBuqADSWP3Lu0lgKs6imDDbuEseB40NNAdXk_O4LDrCnWUm-zS3Kw
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# mediasoup / RTP (reserved for future media server integration)
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# Discovery
DISCOVERY_UDP_PORT=41234
DISCOVERY_BROADCAST_INTERVAL=3

# File Uploads — 0 = unlimited. Absolute path mirroring the SQLite location
# so uploads are also shared with the bundled server.
UPLOAD_DIR=C:/Users/youse/AppData/Roaming/CommClient/data/files
MAX_UPLOAD_SIZE_MB=0
ALLOWED_EXTENSIONS=

# Rate Limiting
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_GENERAL=100/minute
