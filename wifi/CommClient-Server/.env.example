# CommClient Server Configuration
# ================================
# Copy this file to .env and customize as needed.
#
# LAN-only mode: No cloud dependencies. All data stays on local network.
#
# Quick start:
#   1. cp .env.example .env
#   2. Change JWT_SECRET to a random string
#   3. python run.py

# ── Server ─────────────────────────────────────────
HOST=0.0.0.0
PORT=3000
DEBUG=false
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────
# Backend: "sqlite" (default, zero-config) or "postgresql" (production scale)
DB_BACKEND=sqlite

# SQLite (default — no setup required)
SQLITE_PATH=./data/commclient.db

# PostgreSQL (uncomment and configure for production)
# DB_BACKEND=postgresql
# DATABASE_URL=postgresql+asyncpg://commclient:password@localhost:5432/commclient

# ── Authentication ─────────────────────────────────
# IMPORTANT: Change this to a random secret in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=commclient-lan-secret-CHANGE-ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Media / WebRTC ─────────────────────────────────
# Port range reserved for mediasoup RTP (future SFU integration)
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# ── LAN Discovery ─────────────────────────────────
# UDP broadcast port for server discovery
DISCOVERY_UDP_PORT=41234
# How often to broadcast presence (seconds)
DISCOVERY_BROADCAST_INTERVAL=3
# Set to 1 to disable mDNS + UDP broadcast (forces clients to use the
# router instead of auto-discovering this server). Implied by
# HELEN_REQUIRE_ROUTER=1.
# HELEN_DISABLE_BROADCAST=0

# ── Helen-Router (mandatory entry point) ──────────
# Set HELEN_REQUIRE_ROUTER=1 to refuse any client traffic that didn't
# transit a Helen-Router. The router stamps every forwarded request
# with `X-Forwarded-By: helen-router/<token>` and this server verifies
# it. When enabled, mDNS + UDP broadcast are also auto-disabled so
# clients can only reach us through the router.
HELEN_REQUIRE_ROUTER=0

# Shared secret between the router and this server. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
HELEN_ROUTER_TOKEN=

# Where to register this server with the router(s). The server can
# register against MULTIPLE routers in parallel for high availability.
# Three configuration styles, mix as needed:
#
#   1. Single router (legacy):
#        HELEN_ROUTER_URL=http://10.0.0.5:8080
#
#   2. Multiple routers, same shared token:
#        HELEN_ROUTER_URLS=http://10.0.0.5:8080,http://10.0.1.5:8080,http://10.0.2.5:8080
#
#   3. Multiple routers, per-router tokens (rare):
#        HELEN_ROUTER_TOKENS=http://10.0.0.5:8080=tokA,http://10.0.1.5:8080=tokB
#
#   4. Pure auto-discovery via mDNS (no static config) — the server
#      browses _helen-router._tcp.local and registers with whatever
#      it finds, using HELEN_ROUTER_TOKEN. Disable with:
#        HELEN_ROUTER_NO_MDNS=1
# HELEN_ROUTER_URL=
# HELEN_ROUTER_URLS=

# Optional: explicit URL the router(s) should use to reach us. Default
# is autodetected from psutil interfaces. Override if you bind to a
# specific NIC or sit behind an internal NAT.
# HELEN_ROUTER_SELF_URL=http://10.0.0.10:3000

# ── File Uploads ───────────────────────────────────
UPLOAD_DIR=./data/files
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.bmp,.webp,.pdf,.doc,.docx,.xls,.xlsx,.zip,.rar,.7z,.txt,.mp3,.mp4,.wav,.ogg,.mov,.avi,.mkv

# ── Rate Limiting ──────────────────────────────────
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_GENERAL=100/minute
